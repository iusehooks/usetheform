  "private": true,
  "scripts": {
    "docz:dev": "yarn run clean && cross-env NODE_OPTIONS=--openssl-legacy-provider docz dev",
    "docz:build": "yarn run clean && cross-env NODE_OPTIONS=--openssl-legacy-provider docz build",
    "clean": "rimraf .docz && cross-env NODE_OPTIONS=--openssl-legacy-provider  docz clean",
    "docz:serve": "yarn run clean && yarn run build && cross-env NODE_OPTIONS=--openssl-legacy-provider docz serve"
  },
