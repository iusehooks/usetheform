    "@babel/plugin-transform-classes": "7.12.1",
    "@babel/preset-env": "7.12.11",
    "@babel/preset-react": "7.12.10",
    "@babel/types": "7.16.0",
    "@reach/router": "^1.3.4",
    "babel-core": "7.0.0-bridge.0",
    "babel-plugin-lodash": "3.3.4",
